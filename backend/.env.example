# Database — must match docker-compose postgres service credentials
DATABASE_URL=postgresql+asyncpg://shadowing:shadowing@postgres:5432/shadowing_queue

# CORS — origin of the Next.js frontend
FRONTEND_URL=http://localhost:3000

# "development" enables SQLAlchemy echo and debug tooling
ENVIRONMENT=development

# Keigo Translator — get a free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here
